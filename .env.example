# Canonical public site URL (no trailing slash). Used when set for OAuth
# redirectTo and server redirects. On Vercel Production use https://idlebrew.app.
# On Preview, omit so redirectTo uses the browser origin and the callback route
# uses x-forwarded-host (allow https://*-.vercel.app/** in Supabase Redirect URLs).
# NEXT_PUBLIC_SITE_URL=https://idlebrew.app

# Optional: force OAuth redirectTo to this exact URL (advanced). Omit on previews
# unless every OAuth completion should hit one host.
# NEXT_PUBLIC_AUTH_CALLBACK_URL=https://idlebrew.app/auth/callback

# Supabase local defaults. Replace them with hosted project settings for
# remote development.
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Service-role key — needed by the MCP server when authenticating via API key
# (lookups against mcp_api_keys must bypass RLS). Get from `supabase status`
# locally or Studio → Settings → API in production. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway key — single key that authorizes calls to every model
# the deck assistant supports (Anthropic / Google / OpenAI). Get one from
# vercel.com → Storage → AI Gateway. The SDK also accepts AI_GATEWAY_API_KEY
# as an alias if you prefer that name.
VERCEL_AI_GATEWAY_KEY=
AI_GATEWAY_API_KEY=

# Local primer/editor links that the sanitizer should allow in development.
NEXT_PUBLIC_IDLEBREW_HOSTS=localhost:3000,127.0.0.1:3000,idlebrew.app,www.idlebrew.app,*.decamuns-projects.vercel.app

# Feedback form (/feedback): Cloudflare Turnstile + Resend
# https://developers.cloudflare.com/turnstile/ — create a widget and use Managed mode for the site key + secret.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# https://resend.com — verify sending domain, then set a verified "from" address.
RESEND_API_KEY=
# Defaults: feedback@idlebrew.app and Idlebrew <noreply@idlebrew.app>
# FEEDBACK_TO_EMAIL=
# FEEDBACK_FROM_EMAIL=

# OAuth providers - only needed for local Supabase dev (supabase start)
# Production credentials are stored in the Supabase dashboard, not here
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=your-facebook-app-id
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=your-facebook-app-secret

# --- Google AdSense (issue #215; human-approved lines in #209) ---
# Multi-line `ads.txt` served at /ads.txt (plain text). Set in Vercel; do not commit live seller records.
# ADS_TXT=google.com, pub-0000000000000000, DIRECT, f08c47fec0942fa0
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-0000000000000000
# NEXT_PUBLIC_ADSENSE_DISPLAY_SLOT_ID=0000000000
# Optional: load AdSense on local `npm run dev` (default off so dev does not hit Google).
# NEXT_PUBLIC_ADSENSE_ALLOW_IN_DEV=1
# Optional: Consent Mode v2 defaults (denied) before ads/analytics — pair with a consent UI for EEA/UK.
# NEXT_PUBLIC_GOOGLE_CONSENT_MODE_V2=1
