# Supabase local defaults. Replace them with hosted project settings for
# remote development.
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Service-role key — needed by the MCP server when authenticating via API key
# (lookups against mcp_api_keys must bypass RLS). Get from `supabase status`
# locally or Studio → Settings → API in production. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway key — single key that authorizes calls to every model
# the deck assistant supports (Anthropic / Google / OpenAI). Get one from
# vercel.com → Storage → AI Gateway. The SDK also accepts AI_GATEWAY_API_KEY
# as an alias if you prefer that name.
VERCEL_AI_GATEWAY_KEY=
AI_GATEWAY_API_KEY=

# Local primer/editor links that the sanitizer should allow in development.
NEXT_PUBLIC_IDLEBREW_HOSTS=localhost:3000,127.0.0.1:3000,idlebrew.app,www.idlebrew.app,*.decamuns-projects.vercel.app

# OAuth providers - only needed for local Supabase dev (supabase start)
# Production credentials are stored in the Supabase dashboard, not here
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
SUPABASE_AUTH_EXTERNAL_FACEBOOK_CLIENT_ID=your-facebook-app-id
SUPABASE_AUTH_EXTERNAL_FACEBOOK_SECRET=your-facebook-app-secret
