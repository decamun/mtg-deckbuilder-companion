{
  "name": "idlebrew",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:all": "npx supabase start && docker compose up -d",
    "stop:all": "docker compose down && npx supabase stop",
    "restart:all": "npm run stop:all && npm run dev:all",
    "agent:up": "docker compose -f docker-compose.agent.yml up -d",
    "agent:down": "docker compose -f docker-compose.agent.yml down",
    "agent:port": "docker compose -f docker-compose.agent.yml port web 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:p0-security": "node scripts/test-p0-security.mjs",
    "test:deck-service": "node scripts/test-deck-service-validation.mjs",
    "test:deck-format": "node scripts/test-deck-format-validation.mjs",
    "agent:pro-account": "node scripts/provision-agent-pro-account.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^2.0.0",
    "@ai-sdk/react": "^2.0.0",
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@marsidev/react-turnstile": "^1.5.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "resend": "^6.12.3",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
